# PostgreSQL
POSTGRES_USER=neoqueue
POSTGRES_PASSWORD=changeme
POSTGRES_DB=neoqueue

# Constructed by docker-compose — override only if running outside Docker
DATABASE_URL=postgresql://neoqueue:changeme@postgres:5432/neoqueue

# Redis
REDIS_URL=redis://redis:6379/0

# Worker
WORKER_HEARTBEAT_INTERVAL=10   # seconds between heartbeat writes
WORKER_JOB_TIMEOUT=300         # seconds before watchdog considers a job stuck
WORKER_REPLICAS=2              # default worker scale

# Watchdog
WATCHDOG_POLL_INTERVAL=30      # seconds between watchdog scans
MAX_RETRIES=3                  # max retry attempts before marking job as dead

# App
ENV=development                # set to production in prod
VITE_API_URL=http://localhost:8000
